# Autonomous Bug Fixer - Configuration

#   Local: REPO_PATH=C:/Users/you/projects/buggy-app
#   Git:   REPO_PATH=https://github.com/user/repo.git
# REPO_PATH= C:/Users/anees/PycharmProjects/pythonProject/files/testing
REPO_PATH=C:\Users\anees\PycharmProjects\pythonProject\autonomous_bug_fixer\testing

# LLM API Keys
# System will use Anthropic if available, fallback to OpenAI

# Anthropic Claude API Key (get from: https://console.anthropic.com/)
ANTHROPIC_API_KEY=key

# OpenAI API Key (get from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=key


# Maximum cost in USD
# System will stop if this budget is exceeded
COST_LIMIT=5.0

# Maximum total iterations across all bugs
MAX_ITERATIONS=10

# Maximum attempts per single bug before giving up 
# Attempt 1-3: Direct LLM (one per model), Attempt 4-5: CrewAI
MAX_ATTEMPTS_PER_BUG=5

# Output directory for logs and reports (default: ./output)
OUTPUT_DIR=./output

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO